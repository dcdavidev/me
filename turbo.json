{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "CI"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "$NODE_ENV"],
      "outputs": [".react-router/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "$NODE_ENV"],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prisma:generate": {
      "dependsOn": ["^prisma:generate"],
      "inputs": ["$TURBO_DEFAULT", ".env*", "$NODE_ENV"],
      "outputs": ["src/prisma/**"]
    },
    "prisma:migrate:dev": {
      "dependsOn": ["^prisma:migrate:dev"],
      "inputs": ["$TURBO_DEFAULT", ".env*", "$NODE_ENV"],
      "outputs": ["prisma/migrations/**"]
    }
  }
}
